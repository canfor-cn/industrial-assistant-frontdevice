{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WakeFusion Terminal",
  "version": "0.1.0",
  "identifier": "com.industrial.assistant.wakefusion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "WakeFusion Terminal",
        "width": 1720,
        "height": 980,
        "resizable": true,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [],
    "targets": [],
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
